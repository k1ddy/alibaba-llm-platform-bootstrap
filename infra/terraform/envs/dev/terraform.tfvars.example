project_name = "alibaba-llm-platform"
environment  = "dev"

# Replace with the target Alibaba region for the demo environment.
alicloud_region = "cn-hangzhou"
alicloud_account_id = "5864273999854348"

vpc_cidr = "10.40.0.0/16"
private_vswitch_cidrs = [
  "10.40.1.0/24",
  "10.40.2.0/24",
]

# Validated as creatable in `cn-hangzhou` on 2026-03-27.
# Re-check ACK metadata before any live cluster creation.
kubernetes_version = "1.34.3-aliyun.1"

# Keep disabled until a separate cost review approves cluster creation.
ack_enabled = false

tags = {
  owner   = "career-prep"
  purpose = "platform-bootstrap"
}
